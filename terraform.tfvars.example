# ============================================================
# terraform.tfvars.example
# terraform.tfvars로 복사한 뒤 실제 값을 입력하세요.
# 민감 정보가 포함될 수 있으므로 terraform.tfvars는 절대 commit 하지 마세요.
# ============================================================

# Azure 구독 및 테넌트 (az account show 로 확인)
subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
tenant_id       = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Azure Container Registry 이름 (전역 고유, 영숫자만, 5-50자)
acr_name = "acryk8sdemo12345"

# Key Vault 접미사 — 전역 고유 이름 생성용 (영숫자 3-8자)
kv_suffix = "abc123"

# Jump VM SSH 접속 설정
# 키가 없으면 아래 명령으로 생성:
#   ssh-keygen -t rsa -b 4096 -f ~/.ssh/id_rsa_jumpbox -C "jumpbox"
# 생성 후 공개키 내용을 아래에 붙여넣기:
#   cat ~/.ssh/id_rsa_jumpbox.pub
jumpbox_admin_username = "azureadmin"
jumpbox_ssh_public_key = "ssh-rsa AAAA... your-public-key-here"

# cert-manager DNS-01 챌린지용 DNS Zone (선택 사항, 비워두면 생략)
# dns_zone_id = "/subscriptions/.../resourceGroups/.../providers/Microsoft.Network/dnsZones/example.com"

# --- 환경 설정 (기본값이 있어 선택 사항) ---
# location              = "koreacentral"
# prefix                = "k8s"
# kubernetes_version    = "1.35"

# --- VM 크기 ---
# vm_size_system        = "Standard_D2s_v4"
# vm_size_ingress       = "Standard_D2s_v4"
# vm_size_jumpbox       = "Standard_B2s"

# --- SKU / 가격 등급 ---
# aks_sku_tier          = "Standard"     # Free | Standard
# acr_sku               = "Basic"        # Basic | Standard | Premium
# bastion_sku           = "Basic"        # Basic | Standard
# keyvault_sku          = "standard"     # standard | premium

# --- 보존기간 ---
# log_retention_days        = 30
# flow_log_retention_days   = 30
# backup_retention_duration = "P7D"

# --- 보안 ---
# keyvault_purge_protection = true       # 기본값: true (demo: false로 override)
# grafana_public_access     = false      # 기본값: false (demo: true로 override)
# grafana_sku               = "Standard" # Standard | Essential
# backup_soft_delete        = false      # 기본값: false (prod: true 권장)

# --- 관측성 ---
# enable_grafana            = true
# enable_sentinel           = false

# 리소스 태그
tags = {
  project     = "azure-k8s"
  environment = "demo"
  managed_by  = "opentofu"
  owner       = "your-name"
}
